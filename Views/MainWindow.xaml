<Window x:Class="AnimalsApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AnimalsApp.ViewModels"
        Title="Animals" Height="400" Width="700">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <!-- СОБАКА -->
        <TextBlock Text="Собака" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1">
            <Button Content="Двигаться" Click="MoveDog_Click" Margin="5"/>
            <Button Content="Стоять" Click="StopDog_Click" Margin="5"/>
            <Button Content="Гав" Click="BarkDog_Click" Margin="5"/>
        </StackPanel>

        <TextBlock Text="{Binding DogOutput}" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>

        <!-- ПАНТЕРА -->
        <TextBlock Text="Пантера" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1">
            <Button Content="Двигаться" Click="MovePanther_Click" Margin="5"/>
            <Button Content="Стоять" Click="StopPanther_Click" Margin="5"/>
            <Button Content="Рычать" Click="RoarPanther_Click" Margin="5"/>
            <Button Content="На дерево" Click="ClimbTree_Click" Margin="5"/>
        </StackPanel>

        <TextBlock Text="{Binding PantherOutput}" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"/>

        <!-- ЧЕРЕПАХА -->
        <TextBlock Text="Черепаха" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1">
            <Button Content="Двигаться" Click="MoveTurtle_Click" Margin="5"/>
            <Button Content="Стоять" Click="StopTurtle_Click" Margin="5"/>
        </StackPanel>

        <TextBlock Text="{Binding TurtleOutput}" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center"/>
    </Grid>
</Window>